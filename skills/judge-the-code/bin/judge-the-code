#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SETUP_MARKER="$SKILL_DIR/.setup-complete"

if [ ! -f "$SETUP_MARKER" ]; then
  echo "❌ judge-the-code is not set up in this directory yet." >&2
  echo "   Run setup first from the current skill directory:" >&2
  echo "   $SKILL_DIR/setup" >&2
  exit 1
fi

exec "$SCRIPT_DIR/run-judge" "$@"
