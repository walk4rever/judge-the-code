#!/usr/bin/env bash
# code-explore setup — download syft + scc to SKILL_DIR/bin/
# No system-level installation. All binaries stay inside the skill directory.
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
BIN_DIR="$SKILL_DIR/bin"
mkdir -p "$BIN_DIR"

# ── OS / arch detection ───────────────────────────────────────────────────────
OS=$(uname -s)    # Darwin | Linux
ARCH=$(uname -m)  # x86_64 | arm64 | aarch64
[ "$ARCH" = "aarch64" ] && ARCH="arm64"

case "$OS" in
  Darwin|Linux) ;;
  *) echo "❌ Unsupported OS: $OS (supported: macOS, Linux)"; exit 1 ;;
esac
case "$ARCH" in
  x86_64|arm64) ;;
  *) echo "❌ Unsupported arch: $ARCH (supported: x86_64, arm64)"; exit 1 ;;
esac

# ── helpers ───────────────────────────────────────────────────────────────────
latest_version() {
  # $1 = owner/repo  →  echoes version string without leading "v"
  local out
  out=$(curl -sf --max-time 15 "https://api.github.com/repos/$1/releases/latest" 2>/dev/null) || {
    echo "❌ Failed to fetch version for $1 (network error or GitHub rate limit)" >&2
    return 1
  }
  echo "$out" | python3 -c "import json,sys; print(json.load(sys.stdin)['tag_name'].lstrip('v'))" 2>/dev/null || {
    echo "❌ Failed to parse version for $1 (unexpected API response)" >&2
    return 1
  }
}

download_tar() {
  # $1=display_name $2=url $3=binary_name_in_archive
  local name="$1" url="$2" bin="$3"
  echo "  Downloading $name..."

  command -v curl &>/dev/null || { echo "  ❌ curl is required but not found"; return 1; }

  local tmp
  tmp=$(mktemp -d)
  if ! curl -sSfL --retry 3 --max-time 120 "$url" | tar -xz -C "$tmp"; then
    echo "  ❌ Download failed: $url"
    echo "     Check your network connection or try again later."
    rm -rf "$tmp"; return 1
  fi
  local found
  found=$(find "$tmp" -type f -name "$bin" | head -1)
  if [ -z "$found" ]; then
    echo "  ❌ Binary '$bin' not found in archive."
    echo "     Archive contents:"; ls "$tmp"
    rm -rf "$tmp"; return 1
  fi
  mv "$found" "$BIN_DIR/$bin"
  chmod +x "$BIN_DIR/$bin"
  rm -rf "$tmp"
  echo "  ✅ $name → $BIN_DIR/$bin"
}

# ── syft ──────────────────────────────────────────────────────────────────────
# naming: syft_VERSION_darwin_arm64.tar.gz | syft_VERSION_linux_amd64.tar.gz
# VERSION = tag without "v" prefix
install_syft() {
  if [ -x "$BIN_DIR/syft" ]; then echo "  ✅ syft already installed"; return; fi
  local ver; ver=$(latest_version "anchore/syft")
  local os arch
  [ "$OS" = "Darwin" ] && os="darwin" || os="linux"
  [ "$ARCH" = "x86_64" ] && arch="amd64" || arch="arm64"
  download_tar "syft v${ver}" \
    "https://github.com/anchore/syft/releases/download/v${ver}/syft_${ver}_${os}_${arch}.tar.gz" \
    "syft"
}

# ── scc ───────────────────────────────────────────────────────────────────────
# naming: scc_Darwin_arm64.tar.gz | scc_Linux_x86_64.tar.gz
# OS = Darwin/Linux (capitalized), no version number in filename
install_scc() {
  if [ -x "$BIN_DIR/scc" ]; then echo "  ✅ scc already installed"; return; fi
  local ver; ver=$(latest_version "boyter/scc")
  local os arch
  [ "$OS" = "Darwin" ] && os="Darwin" || os="Linux"
  [ "$ARCH" = "x86_64" ] && arch="x86_64" || arch="arm64"
  download_tar "scc v${ver}" \
    "https://github.com/boyter/scc/releases/download/v${ver}/scc_${os}_${arch}.tar.gz" \
    "scc"
}

# ── main ──────────────────────────────────────────────────────────────────────
echo "🔧 code-explore setup"
echo "   Platform: $OS/$ARCH"
echo "   Install dir: $BIN_DIR"
echo ""

FAILED=0
install_syft || FAILED=$((FAILED+1))
install_scc  || FAILED=$((FAILED+1))

echo ""
if [ "$FAILED" -eq 0 ]; then
  echo "✅ All tools ready. (~35MB total)"
  echo "   Run: /code-explore <path>"
else
  echo "⚠️  $FAILED tool(s) failed to install."
  echo "   code-explore will run in fallback mode (pure LLM, no tool enhancement)."
  echo "   Re-run this script once network is available to complete setup."
fi
